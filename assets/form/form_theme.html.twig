        }
    ) }}
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
        {% set error_translation_domain = form.vars.translation_domain is defined
            ? form.vars.translation_domain
            : translation_domain
        %}
        {% if form.parent is null %}
            <div class="form--errors">
                <ul>
                    {% for error in errors %}
                        <li>{{ error.message|trans(error.messageParameters, error_translation_domain) }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% else %}
            <div class="form--field-errors">
                <ul>
                    {% for error in errors %}
                        <li>{{ error.message|trans(error.messageParameters, error_translation_domain) }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}

{% block form_help %}
    {% if help is not empty %}
        {% set help_key = help %}
        {% if help_key is same as(true) %}
            {% set help_key = 'field.' ~ form.vars.name ~ '.help' %}
        {% endif %}
        <div class="form--help">
            {{ help_key|trans(help_translation_parameters, translation_domain) }}
        </div>
    {% endif %}
{% endblock %}
