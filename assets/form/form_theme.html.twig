{% block select_input_widget %}
    {% set label_key = form.vars.label is same as(false)
        ? form.vars.name
        : (form.vars.label ?? form.vars.name)
    %}
    {% if label_key is same as(true) %}
        {% set label_key = 'field.' ~ form.vars.name ~ '.label' %}
    {% endif %}
    {% set label_value = form.vars.translation_domain is same as(false)
        ? label_key
        : label_key|trans({}, form.vars.translation_domain)
    %}
    {% set placeholder_key = form.vars.placeholder ?? null %}
    {% if placeholder_key is same as(true) %}
        {% set placeholder_key = 'field.' ~ form.vars.name ~ '.placeholder' %}
    {% endif %}
    {% set placeholder_value = placeholder_key %}
    {% if placeholder_key is not null and form.vars.translation_domain is not same as(false) %}
        {% set placeholder_value = placeholder_key|trans({}, form.vars.translation_domain) %}
    {% endif %}
    {% set normalized_choices = [] %}
    {% for choice in form.vars.choices %}
        {% if choice.choices is defined %}
            {% set group = {'label': choice.label, 'options': []} %}
            {% for option in choice.choices %}
                {% set group = group|merge({'options': group.options|merge([{'value': option.value, 'label': option.label}])}) %}
            {% endfor %}
            {% set normalized_choices = normalized_choices|merge([group]) %}
        {% else %}
            {% set normalized_choices = normalized_choices|merge([{'value': choice.value, 'label': choice.label}]) %}
        {% endif %}
    {% endfor %}
    {{ component(
        render_pass,
        '@WexampleSymfonyDesignSystemBundle/components/form/select_input',
        {
            name: full_name,
            id: id,
            label: label_value,
            placeholder: placeholder_value,
            required: required,
            multiple: form.vars.multiple ?? false,
            selected: value,
            choices: normalized_choices
        }
    ) }}
{% endblock %}

{% block password_input_widget %}
